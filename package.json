    "blur:video": "dotenv -e .env.local -- tsx scripts/blur-video-test.ts",
    "blur:video:selftest": "tsx scripts/blur-video-selftest.ts",
    "blur:webhook:test": "tsx scripts/blur-webhook-test.ts"
