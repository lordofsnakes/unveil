{
  "name": "mpp-onlyfans",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "SERWIST_SUPPRESS_TURBOPACK_WARNING=1 next build --webpack",
    "start": "next start",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "tempo:wallets:migrate": "dotenv -e .env.local -- tsx scripts/migrate-tempo-wallets.ts",
    "key:init": "dotenv -e .env.local -- tsx scripts/init-platform-key.ts",
    "key:rotate": "dotenv -e .env.local -- tsx scripts/init-platform-key.ts --rotate",
    "seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "token:create": "dotenv -e .env.local -- tsx scripts/create-token.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.5",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@radix-ui/react-accordion": "^1.2.14",
    "@serwist/next": "^9.5.11",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.0",
    "@vercel/blob": "^2.4.1",
    "@vercel/og": "^0.11.1",
    "accounts": "^0.14.9",
    "drizzle-orm": "^0.45.2",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "mppx": "^0.7.0",
    "next": "16.2.9",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "replicate": "^1.4.0",
    "sharp": "^0.35.1",
    "stripe": "^22.2.2",
    "svix": "^1.96.0",
    "viem": "^2.52.2",
    "wagmi": "^3.6.17"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-linux-x64": "1.3.0",
    "@img/sharp-linux-x64": "0.35.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "serwist": "^9.5.11",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
