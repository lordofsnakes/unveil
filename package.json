    "accounts": "^0.14.9",
    "drizzle-orm": "^0.45.2",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "mppx": "^0.7.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "replicate": "^1.4.0",
    "sharp": "^0.35.1",
    "svix": "^1.96.0",
    "viem": "^2.52.2",
    "wagmi": "^3.6.17"
